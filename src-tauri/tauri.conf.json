{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Akış",
  "version": "2.0.0",
  "identifier": "com.hamitparlak.akis",
  "build": {
    "beforeDevCommand": "npm run desktop:serve",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Akış",
        "width": 1500,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["main-workspace"],
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"]
      }
    }
  }
}
