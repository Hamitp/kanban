{
  "name": "akis-local-workspace",
  "version": "0.1.0",
  "description": "Yerel çalışan Kanban ve mind map masaüstü uygulaması",
  "author": "Hamit Parlak",
  "main": "desktop/electron/main.cjs",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "desktop:build": "vite build --config vite.desktop.config.ts",
    "desktop:run": "npm run desktop:build && electron .",
    "desktop:pack": "npm run desktop:build && electron-builder --dir",
    "desktop:dist": "npm run desktop:build && electron-builder --win nsis --x64",
    "test": "npm run build && node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern desktop-dist --ignore-pattern release",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "build": {
    "appId": "com.hamitparlak.akis",
    "productName": "Akış",
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "desktop/resources"
    },
    "files": [
      "desktop-dist/**/*",
      "desktop/electron/**/*",
      "desktop/resources/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "icon": "desktop/resources/icon.png",
      "target": [
        "nsis"
      ],
      "artifactName": "Akis-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Akış",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
