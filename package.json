{
  "name": "akis-local-workspace",
  "version": "1.0.1",
  "description": "Çevrimdışı çalışan Kanban panosu ve zihin haritası masaüstü uygulaması",
  "author": "Hamit Parlak",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "npm run desktop:serve",
    "build": "npm run desktop:build",
    "preview": "vite preview --config vite.desktop.config.ts --host 127.0.0.1",
    "desktop:serve": "vite --config vite.desktop.config.ts --host 127.0.0.1 --port 1420 --strictPort",
    "desktop:build": "vite build --config vite.desktop.config.ts",
    "desktop:run": "tauri dev",
    "desktop:dist": "tauri build",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test tests/*.test.mjs",
    "test": "npm run desktop:build && npm run test:unit",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "lucide-react": "1.24.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4"
  }
}
